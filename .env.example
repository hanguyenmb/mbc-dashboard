# Authentication
AUTH_SECRET=generate-a-random-secret-string-here
NEXTAUTH_URL=http://localhost:3000

# Gemini AI (lấy miễn phí tại https://aistudio.google.com/apikey)
GOOGLE_GENERATIVE_AI_API_KEY=AIza...your-key-here

# For production on Vercel, set NEXTAUTH_URL to your actual domain
# e.g., NEXTAUTH_URL=https://mbc-dashboard.vercel.app
